<?php
/**
 * PREMASTER.PHP - Carga de configuración y clases base
 */

// 1. Iniciar sesión PRIMERO
if (session_status() === PHP_SESSION_NONE) {
    @session_start();
}

// 2. Configuración de errores
error_reporting(E_ALL & ~E_STRICT & ~E_DEPRECATED);
ini_set('display_errors', '1');
ini_set('log_errors', '1');
ini_set('error_log', __DIR__ . '/tmp/logs/php_errors.log');

// 3. Timezone
date_default_timezone_set('America/Argentina/Buenos_Aires');

// 4. Paths absolutos
if (!defined('PATHBASE')) {
    define('PATHBASE', __DIR__ . '/');
    define('PATHCLASES', PATHBASE . 'clases/');
    define('PATHFACTORY', PATHBASE . 'factory/');
    define('PATHINCLUDES', PATHBASE . 'includes/');
}

// 5. Función de carga segura
function safe_require($file, $name) {
    if (file_exists($file)) {
        require_once($file);
        return true;
    } else {
        error_log("[PREMASTER] ERROR: No se encontró $name en $file");
        return false;
    }
}

// 6. Cargar clases en orden correcto
safe_require(PATHFACTORY . 'Config.php', 'Config');
safe_require(PATHCLASES . 'Logger.php', 'Logger');
safe_require(PATHFACTORY . 'FactoryExceptions.php', 'FactoryExceptions');
safe_require(PATHFACTORY . 'Funciones.php', 'Funciones');
safe_require(PATHCLASES . 'Html.php', 'Html');
safe_require(PATHFACTORY . 'Enums.php', 'Enums');
safe_require(PATHFACTORY . 'drivers/DbMysql.php', 'DbMysql');
safe_require(PATHFACTORY . 'Factory.php', 'Factory');
safe_require(PATHFACTORY . 'Datos.php', 'Datos');
safe_require(PATHFACTORY . 'Mapper.php', 'Mapper');
safe_require(PATHFACTORY . 'Transaction.php', 'Transaction');
safe_require(PATHFACTORY . 'Cache.php', 'Cache');
safe_require(PATHFACTORY . 'Mutex.php', 'Mutex');
safe_require(PATHCLASES . 'Base.php', 'Base');
safe_require(PATHCLASES . 'Usuario.php', 'Usuario');
safe_require(PATHCLASES . 'UsuarioLogin.php', 'UsuarioLogin');

// 7. Autoloader
if (!function_exists('koi_autoloader')) {
    function koi_autoloader($className) {
        $specialMappings = array(
            'Modos' => PATHFACTORY . 'Enums.php',
            'TiposPersonal' => PATHFACTORY . 'Enums.php',
            'TiposContacto' => PATHFACTORY . 'Enums.php',
            'TiposOperador' => PATHFACTORY . 'Enums.php',
            'LoginFailException' => PATHFACTORY . 'FactoryExceptions.php',
        );
        
        if (array_key_exists($className, $specialMappings)) {
            if (file_exists($specialMappings[$className])) {
                require_once($specialMappings[$className]);
                return;
            }
        }
        
        $paths = array(PATHCLASES, PATHFACTORY, PATHINCLUDES);
        foreach ($paths as $path) {
            $file = $path . $className . '.php';
            if (file_exists($file)) {
                require_once($file);
                return;
            }
        }
    }
    spl_autoload_register('koi_autoloader');
}

// 8. Verificar Factory
try {
    Factory::getInstance();
} catch (Exception $e) {
    error_log('[PREMASTER] Factory falló: ' . $e->getMessage());
}
