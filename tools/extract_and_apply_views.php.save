/var/www/encinitas/tools/extract_and_apply_views.php<?php
// PHP 5.6 compatible - sin typed hints ni ??, etc.

// ====== CONFIG por variables de entorno ======
$MSSQL_HOST = getenv('MSSQL_HOST');   // ej: 192.168.2.100
$MSSQL_PORT = getenv('MSSQL_PORT') ?: '1433';
$MSSQL_USER = getenv('MSSQL_USER');   // ej: koi
$MSSQL_PASS = getenv('MSSQL_PASS');   // ej: koisys
$MSSQL_DB   = getenv('MSSQL_DB');     // ej: encinitas
$TSQL_BIN   = getenv('TSQL_BIN') ?: '/usr/bin/tsql';

$MYSQL_HOST = getenv('MYSQL_HOST');   // ej: 192.168.2.210
$MYSQL_USER = getenv('MYSQL_USER');   // ej: koiuser
$MYSQL_PASS = getenv('MYSQL_PASS');   // ej: Route667?
$MYSQL_DB   = getenv('MYSQL_DB');     // ej: koi1_stage
$MYSQL_COLLATE = getenv('MYSQL_COLLATE'); // opcional
$DO_BASIC_FIX = getenv('DO_BASIC_FIX');   // si =1, limpia [dbo]. y []

// Lista de vistas: por argv (prioridad) o archivo views_list.txt (una por línea)
$views = array();
if ($argc > 1) {
    for ($i = 1; $i < $argc; $i++) $views[] = $argv[$i];
} else {
    $listFile = __DIR__ . '/views_list.txt';
    if (is_file($listFile)) {
        $lines = file($listFile, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
        foreach ($lines as $ln) {
            $ln = trim($ln);
            if ($ln !== '') $views[] = $ln;
        }
    } else {
        fwrite(STDERR, "ERROR: sin vistas. Pase nombres por argv o cree tools/views_list.txt\n");
        exit(1);
    }
}

// Conexión MySQL
$mysqli = @new mysqli($MYSQL_HOST, $MYSQL_USER, $MYSQL_PASS, $MYSQL_DB);
if ($mysqli->connect_errno) {
    fwrite(STDERR, "ERROR MySQL connect: " . $mysqli->connect_error . "\n");
    exit(1);
}
if ($MYSQL_COLLATE) {
    // no fatal si falla
    @$mysqli->query("SET collation_connection='$MYSQL_COLLATE'");
}

// Helpers
function run_tsql($tsql_bin, $host, $port, $user, $pass, $db, $tsql) {
    // Ejecuta tsql con here-doc y devuelve stdout
    $cmd = escapeshellcmd($tsql_bin)
         . ' -H ' . escapeshellarg($host)
         . ' -p ' . escapeshellarg($port)
         . ' -U ' . escapeshellarg($user)
         . ' -P ' . escapeshellarg($pass)
         . ' -D ' . escapeshellarg($db);

    // Preparamos el script T-SQL (SET NOCOUNT + consulta + GO)
    $payload  = "set nocount on\ngo\n" . $tsql . "\n" . "go\n";
    $desc = array(
        0 => array('pipe', 'r'),
        1 => array('pipe', 'w'),
        2 => array('pipe', 'w'),
    );
    $proc = proc_open($cmd, $desc, $pipes);
    if (!is_resource($proc)) return array(false, "no pude lanzar tsql");

    fwrite($pipes[0], $payload);
    fclose($pipes[0]);
    $out = stream_get_contents($pipes[1]); fclose($pipes[1]);
    $err = stream_get_contents($pipes[2]); fclose($pipes[2]);
    $code = proc_close($proc);

    if ($code !== 0) return array(false, "tsql exit=$code stderr=$err");
    return array(true, $out);
}

function clean_tsql_output($raw) {
    // Normaliza EOL
    $raw = str_replace("\r\n", "\n", $raw);
    $raw = str_replace("\r", "\n", $raw);

    $lines = explode("\n", $raw);
    $out = array();
    foreach ($lines as $ln) {
        $t = trim($ln);

        // fuera ruido típico de tsql
        if ($t === '' ) continue;
        if (strpos($t, 'locale is ') === 0) continue;
        if (strpos($t, 'locale charset') === 0) continue;
        if (strpos($t, 'using default charset') === 0) continue;
        if (preg_match('/^[0-9]+>$/', $t)) continue; // prompts "1>" "2>" etc
        if (preg_match('/^\([0-9]+ rows affected\)$/i', $t)) continue;
        if (strcasecmp($t, 'go') === 0) continue;

        $out[] = $ln;
    }
    return implode("\n", $out);
}

function strip_head_create($view, $def) {
    // Quita un posible "CREATE VIEW [dbo].[<view>] AS" al comienzo
    $pattern = '/^\s*CREATE\s+VIEW\s+(\[dbo\]\.)?\[?'.preg_quote($view,'/').'\]?\s+AS\s*/i';
    return preg_replace($pattern, '', $def, 1);
}

$ok = 0; $err = 0;

foreach ($views as $view) {
    $view = trim($view);
    if ($view === '') continue;

    // 1) extraer definición por fragmento (syscomments)
    $tsql = "SELECT c.text
FROM sysobjects so
JOIN sysusers  su ON su.uid = so.uid
JOIN syscomments c ON c.id  = so.id
WHERE so.xtype = 'V'
  AND su.name  = 'dbo'
  AND so.name  = '".str_replace("'", "''", $view)."'
ORDER BY c.colid";

    list($ok_tsql, $payload) = run_tsql($TSQL_BIN, $MSSQL_HOST, $MSSQL_PORT, $MSSQL_USER, $MSSQL_PASS, $MSSQL_DB, $tsql);
    if (!$ok_tsql) {
        echo "❌ $view: error al extraer: $payload\n";
        $err++; continue;
    }

    $body = clean_tsql_output($payload);
    if ($body === '') {
        echo "❌ $view: vacío (¿vista no existe o sin permisos?)\n";
        $err++; continue;
    }

    // 2) limpiar encabezado si vino embebido
    $body = strip_head_create($view, $body);

    // 3) (opcional) fix mínimo
    if ($DO_BASIC_FIX) {
        // quitar [ ] y dbo.
        $body = preg_replace('/\[(.*?)\]/', '$1', $body);
        $body = preg_replace('/\bdbo\./i', '', $body);
    }

    // 4) armar SQL final
    $sql = "CREATE OR REPLACE VIEW `".$mysqli->real_escape_string($view)."` AS\n".$body;
    // asegurar ; final
    if (!preg_match('/;\s*\z/s', $sql)) $sql .= ";\n";

    // 5) aplicar
    if ($mysqli->query($sql)) {
        echo "✅ aplicada: $view\n";
        $ok++;
    } else {
        echo "❌ error en $view: ".$mysqli->error."\n";
        $err++;
        // seguir con la siguiente
    }
}

echo "----\nAplicadas OK: $ok\nErrores: $err\n";
