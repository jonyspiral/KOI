CREATE OR REPLACE VIEW stock14_por_talle_vASSELECT articulos.cod_articulo, colores_por_articulo.cod_color_articulo, IFNULL(stock14.cantidad, 0) AS cantidad, rango_talles.posic_1 AS Talle, IFNULL(stock14.cant_1, 0) AS cALLSELECT articulos.cod_articulo, colores_por_articulo.cod_color_articulo, IFNULL(stock14.cantidad, 0) AS cantidad, rango_talles.posic_5 AS Talle, IFNULL(stock14.cant_5, 0) AS cant_1FROM rango_talles;