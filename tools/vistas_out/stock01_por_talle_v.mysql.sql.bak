CREATE OR REPLACE VIEW `stock01_por_talle_v` AS SELECT articulos.cod_articulo, colores_por_articulo.cod_color_articulo, IFNULL(stock01.cantidad, 0) AS cantidad, rango_talles.posic_1 AS Talle, IFNULL(stock01.cant_1, 0) AS cant_1 FROM rango_talles INant_1 FROM rango_talles INNER JOIN articulos ON rango_talles.cod_rango = articulos.cod_rango LEFT OUTER JOIN (SELECT cod_almacen, cod_articulo, cod_color_articulo, cantidad, cant_6 FROM stock WHERE (cod_almacen = '01')) stock01 RIGHT O;