CREATE OR REPLACE VIEW `movimientos_caja_v_chq` AS SELECT * FROM (SELECT 'E' tipo, 'DC' tipo_documento, dc.cod_acreditar_debitar_cheque numero,(SELECT CONCAT('`', cast)(caja.cod_caja AS VARCHAR) + CONCAT('` ', caja.nombreFROM) acreditar_debitar_cheque_d dc1INNER oday',0) fecha,ac.empresa empresa,ipoc.cod_importe_operacion cod_importe_operacion,'N' anuladoFROM acreditar_debitar_cheque_d acINNER JOIN acreditar_debitar_cheque_c acc ON acc.cod_acreditar_debitar_cheque = ac.cod_acreditar_debitar_cheq;