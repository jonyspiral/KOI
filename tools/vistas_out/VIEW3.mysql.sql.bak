CREATE OR REPLACE VIEW VIEW3ASSELECT TOP 100 colores_por_articulo.catalogo_orden_pagina AS `Position`, 'Spiral' AS Manufacturer, '' AS Supplier, colores_por_articulo.cod_articulo + colores_por_articulo.cod_coloe, familias_producto.nombre AS familia, familias_producto_2.nombre AS familia_ecommere, colores_por_articulo.ecommerce_existe, colores_por_articulo.catalogo, colores_por_articulo.id_tipo_prod;